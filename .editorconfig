root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# google-java-format uses a 2-space indent
[*.java]
indent_size = 2

[*.{yml,yaml,json,xml}]
indent_size = 2

[*.gradle]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
